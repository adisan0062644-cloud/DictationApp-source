<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panelRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="10dp"
    android:background="@drawable/bg_panel">

    <!-- 1. REC -->
    <FrameLayout
        android:id="@+id/recBtn"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:background="@drawable/bg_rec"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/timerInBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/labelInBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rec"
                android:textColor="@color/white"
                android:textSize="9sp"
                android:alpha="0.85"
                android:letterSpacing="0.08"/>
        </LinearLayout>
    </FrameLayout>

    <View
        android:id="@+id/divider1"
        android:layout_width="1dp"
        android:layout_height="34dp"
        android:layout_marginHorizontal="6dp"
        android:background="@color/line"/>

    <!-- 2. Пауза -->
    <ImageButton
        android:id="@+id/pauseBtn"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_pause"
        android:background="@drawable/bg_aux"
        android:contentDescription="@string/cd_pause"/>

    <!-- 3. Стоп -->
    <ImageButton
        android:id="@+id/stopBtn"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="6dp"
        android:src="@drawable/ic_stop"
        android:background="@drawable/bg_aux"
        android:contentDescription="@string/cd_stop"/>

    <View
        android:id="@+id/divider2"
        android:layout_width="1dp"
        android:layout_height="34dp"
        android:layout_marginHorizontal="8dp"
        android:background="@color/line"/>

    <!-- Таймер большой -->
    <TextView
        android:id="@+id/timerBig"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="74dp"
        android:gravity="center"
        android:text="00:00.0"
        android:textColor="@color/text"
        android:textSize="16sp"
        android:fontFamily="monospace"/>

    <View
        android:id="@+id/divider3"
        android:layout_width="1dp"
        android:layout_height="34dp"
        android:layout_marginHorizontal="8dp"
        android:background="@color/line"/>

    <!-- Открыть приложение -->
    <ImageButton
        android:id="@+id/openAppBtn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_open"
        android:background="@drawable/bg_aux"
        android:contentDescription="@string/cd_open_app"/>

    <!-- Закрыть -->
    <ImageButton
        android:id="@+id/closeBtn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="4dp"
        android:src="@drawable/ic_close"
        android:background="@drawable/bg_aux"
        android:contentDescription="@string/cd_hide_panel"/>

    <!-- Поле результата (раскрывается при получении) -->
    <TextView
        android:id="@+id/resultText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:textColor="@color/text"
        android:textSize="12sp"
        android:padding="8dp"
        android:background="@drawable/bg_edit"
        android:maxLines="4"
        android:ellipsize="end"/>

</LinearLayout>